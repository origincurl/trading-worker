{
  "name": "trading-worker",
  "version": "0.0.1",
  "description": "Worker runtime — collector / calculator / executor / detector roles",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:chart-archive-s3-it": "jest chart-archive-s3.integration.spec.ts --runInBand",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "migrate:run": "ts-node --transpile-only -r tsconfig-paths/register scripts/migrate.ts",
    "probe:kiwoom-ws": "ts-node --transpile-only -r tsconfig-paths/register scripts/probe-kiwoom-ws-concurrency.ts",
    "probe:kiwoom-chart-range": "ts-node --transpile-only -r tsconfig-paths/register scripts/probe-kiwoom-chart-range.ts",
    "chart:archive-one": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-one.ts",
    "chart:repair-derived-one": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-repair-derived-one.ts",
    "chart:backfill": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-backfill.ts",
    "chart:s3-smoke": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-s3-smoke.ts",
    "chart:e2e-smoke": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-e2e-smoke.ts",
    "chart:calendar-import": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-calendar-import.ts",
    "chart:kiwoom-capture": "ts-node --transpile-only -r tsconfig-paths/register scripts/chart-archive-kiwoom-capture.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1054.0",
    "@nestjs/bullmq": "^11.0.3",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-ws": "^11.1.19",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/typeorm": "^11.0.1",
    "@nestjs/websockets": "^11.1.19",
    "bullmq": "^5.34.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^16.6.1",
    "ioredis": "^5.10.1",
    "nodemailer": "^8.0.7",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "ulid": "^2.3.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.6.0",
    "@swc/core": "^1.10.7",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^8.0.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.18.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-decorator-position": "^6.1.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@config/(.*)$": "<rootDir>/config/$1",
      "^@health/(.*)$": "<rootDir>/health/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@external/(.*)$": "<rootDir>/external/$1",
      "^@admin/(.*)$": "<rootDir>/admin/$1",
      "^@roles/(.*)$": "<rootDir>/roles/$1"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
