# ----- Runtime identity -----
NODE_ENV=development
# CSV of active roles. Allowed: collector,tracker,calculator,executor,detector,notifier
ROLES=collector,tracker,calculator,executor,detector,notifier
WORKER_INSTANCE_ID=worker-local
PORT=4002

# Sharding (optional). Both must be set together. SHARD_INDEX < SHARD_COUNT.
SHARD_INDEX=
SHARD_COUNT=

# ----- Market environment (Kiwoom) -----
# Must be 'mock' or 'production'. URL hostnames are cross-checked against this.
# Mock:        wss://mockapi.kiwoom.com:10000/api/dostk/websocket
# Production:  wss://api.kiwoom.com:10000/api/dostk/websocket
KIWOOM_MARKET_ENV=mock
KIWOOM_WS_URL=wss://mockapi.kiwoom.com:10000/api/dostk/websocket
KIWOOM_REST_URL=https://mockapi.kiwoom.com

# Phase C: vendor app key / app secret env vars are gone. Worker reads
# credentials from collector_credentials + api_credentials in DB (loaded
# by admin in BE) and decrypts them using CREDENTIAL_ENCRYPTION_KEY.

# ----- Credential encryption -----
# MUST match the BE value. Both processes share the same key so worker
# can decrypt rows that BE encrypted at admin-write time.
CREDENTIAL_ENCRYPTION_KEY=
# Optional dedicated HMAC secret for the app_key_hash column. Defaults to
# CREDENTIAL_ENCRYPTION_KEY when unset. Must match the BE value either way.
CREDENTIAL_APP_KEY_HASH_SECRET=

# ----- Notify -----
# Supported platforms: SMS, TELEGRAM, DISCORD, SLACK, PUSH. All currently
# have mock impls only — per-platform env vars (api keys, default webhooks,
# device tokens, etc.) will be introduced when each platform's real
# api-client lands.

# ----- Collector -----
# Log every WS tx/rx frame (verbose). Default false. Tokens are still redacted.
COLLECTOR_WS_LOG_FRAMES=false
COLLECTOR_SUBSCRIBE_MARKET_INDEX=true
# Phase E: stock list sync flag. Default true; set false to disable the
# periodic stocks-table refresh from vendor master.
COLLECTOR_STOCK_LIST_SYNC_ENABLED=true
# Enables periodic non-WS header snapshots. KOSPI/KOSDAQ are supplied by Kiwoom WS 0J.
COLLECTOR_MARKET_SNAPSHOT_ENABLED=true
COLLECTOR_INDEX_INTERVAL_SEC=300
COLLECTOR_FX_INTERVAL_SEC=300
COLLECTOR_FX_LATEST_URL=https://cdn.moneyconvert.net/api/latest.json

# ----- Admin HTTP -----
# Bearer token that gates /admin/* endpoints. Unset → admin surface
# completely refuses all requests. Production should rotate regularly.
ADMIN_TOKEN=

# ----- Logging -----
# CSV of Nest log levels. Empty (default) shows log,warn,error,fatal only
# (no debug). Add "debug" / "verbose" when investigating an issue.
LOG_LEVEL=

# ----- Tracker -----
# Polling intervals for balance/position sync. Worker-policy cache overrides
# at runtime via DB worker_policies. Production default is intentionally
# low-frequency; execution WS/fill processing is the primary fast path.
TRACKER_BALANCE_POLL_INTERVAL_SEC=60
TRACKER_POSITION_POLL_INTERVAL_SEC=60
TRACKER_ACCOUNT_SNAPSHOT_REFRESH_DEBOUNCE_MS=2000
# Phase F: TRACKER_ACCOUNT_TARGETS removed. Tracker now reads active
# accounts directly from accounts/account_credentials.
TRACKER_WS_LEASE_TTL_SEC=30
TRACKER_WS_LEASE_RENEW_INTERVAL_MS=5000

# ----- Notifier -----
NOTIFIER_OUTBOX_TICK_MS=1000
NOTIFIER_OUTBOX_BATCH_SIZE=20
NOTIFIER_OUTBOX_MAX_ATTEMPTS=5

# ----- Worker policy cache -----
# Refresh interval for DB-pulled WorkerPolicy values used by scheduler/poll loops.
WORKER_POLICY_REFRESH_INTERVAL_SEC=60

# ----- Persistence -----
# Empty → boots without DB, /ready reports unconfigured.
WORKER_DATABASE_URL=

# ----- Redis (pubsub / streams / bullmq) -----
# Empty → boots without Redis, /ready reports unconfigured.
REDIS_URL=
REDIS_KEY_PREFIX=worker
REDIS_LATEST_TTL_SEC=60
REDIS_MARKET_SNAPSHOT_TTL_SEC=600
REDIS_HEARTBEAT_TTL_SEC=45
REDIS_HEARTBEAT_INTERVAL_SEC=10

# Phase 1-4: opt-in Valkey/Redis shared credential limiter.
# false keeps the existing process-local limiter as the active guard.
WORKER_SHARED_RATE_LIMIT_ENABLED=false
WORKER_SHARED_RATE_LIMIT_LEASE_TTL_MS=30000
