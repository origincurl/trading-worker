# ----- Runtime identity -----
NODE_ENV=development
# CSV of active roles. Allowed: collector,calculator,executor,detector
ROLES=collector,calculator,executor,detector
WORKER_INSTANCE_ID=worker-local
PORT=4002

# Sharding (optional). Both must be set together. SHARD_INDEX < SHARD_COUNT.
SHARD_INDEX=
SHARD_COUNT=

# ----- Market environment (Kiwoom) -----
# Must be 'mock' or 'production'. URL hostnames are cross-checked against this.
# Mock:        wss://mockapi.kiwoom.com:10000/api/dostk/websocket
# Production:  wss://api.kiwoom.com:10000/api/dostk/websocket
KIWOOM_MARKET_ENV=mock
KIWOOM_WS_URL=wss://mockapi.kiwoom.com:10000/api/dostk/websocket
KIWOOM_REST_URL=https://mockapi.kiwoom.com

# Vendor credentials are role-isolated. COLLECTOR key MUST differ from EXECUTOR
# key — they share neither rate limit nor session. Required only when the
# matching role is in ROLES.
KIWOOM_COLLECTOR_APP_KEY=
KIWOOM_COLLECTOR_APP_SECRET=
KIWOOM_EXECUTOR_APP_KEY=
KIWOOM_EXECUTOR_APP_SECRET=

# Legacy single-key vars (Phase 6 retires these). Used as fallback for
# KIWOOM_COLLECTOR_* if the COLLECTOR vars are blank. Do not commit real values.
KIWOOM_APP_KEY=
KIWOOM_APP_SECRET=

# Pre-issued vendor access token. Phase 6 uses this for WS LOGIN until
# Phase 6.8 implements /oauth2/token issuance + refresh.
KIWOOM_ACCESS_TOKEN=

# ----- BE control-plane (HMAC-signed) -----
BE_CONTROL_PLANE_URL=http://localhost:4000
BE_HMAC_SECRET=
# When true, BE control-plane calls are answered by an in-memory mock
# (dev only). Production MUST leave this false.
BE_CONTROL_PLANE_MOCK=false

# ----- Notify (detector only) -----
SLACK_DEFAULT_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# ----- Collector (Phase 6) -----
# Bootstrap symbols (CSV) for tick subscription. Phase 6.7 replaces this
# with dynamic BE universe lease. Leave empty to connect WS but not REG
# anything (useful during smoke tests).
COLLECTOR_BOOTSTRAP_SYMBOLS=
# Log every WS tx/rx frame (verbose). Default false. Tokens are still redacted.
COLLECTOR_WS_LOG_FRAMES=false

# ----- Admin HTTP (Phase 10) -----
# Bearer token that gates /admin/* endpoints. Unset → admin surface
# completely refuses all requests. Production should rotate regularly.
ADMIN_TOKEN=

# ----- Persistence -----
# Empty → Phase 1 boots without DB, /ready reports unconfigured. Required from
# Phase 2 onward. Falls back to MARKET_RUNTIME_DATABASE_URL for compat.
WORKER_DATABASE_URL=

# ----- Redis (pubsub / streams / bullmq) -----
# Empty → boots without Redis, /ready reports unconfigured.
REDIS_URL=
REDIS_KEY_PREFIX=worker
REDIS_LATEST_TTL_SEC=60
REDIS_HEARTBEAT_TTL_SEC=30
REDIS_HEARTBEAT_INTERVAL_SEC=10
